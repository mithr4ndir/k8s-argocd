# Bootstrap resource — apply once manually:
#   kubectl create secret generic onepassword-service-account-token \
#     -n external-secrets \
#     --from-literal=token=$(cat ~/.config/op/service-account-token)
#
# Uses the read-only service account (quasarlab-automation).
# This is the only secret that must be created manually — all others
# are managed by External Secrets Operator pulling from 1Password.
apiVersion: v1
kind: Secret
metadata:
  name: onepassword-service-account-token
  namespace: external-secrets
type: Opaque
stringData:
  token: CHANGE_ME
