# Apply manually — do NOT commit actual token to git:
#
# kubectl create secret generic onepassword-service-account-token \
#   -n external-secrets \
#   --from-literal=token=<YOUR_1PASSWORD_SERVICE_ACCOUNT_TOKEN>
#
# Use the read-only service account token (quasarlab-automation).
apiVersion: v1
kind: Secret
metadata:
  name: onepassword-service-account-token
  namespace: external-secrets
type: Opaque
stringData:
  token: CHANGE_ME
